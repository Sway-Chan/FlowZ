# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build output
dist/
dist-ssr/
dist-package/
release/
*.local
*.asar

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
*.log
[Ll]og/
[Ll]ogs/

# Test files
samples/
*.test.exe

# Development scripts (keep in repo but ignore generated)
scripts/*.exe

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini

# Temporary files
*.tmp
*.temp

# Local test files (may contain private config)
test-*.json

# ── Sensitive runtime data (NEVER commit) ──────────────────────────────
# User proxy configs & node lists (stored in OS userData dir at runtime,
# but guard against any accidental copies landing in the repo)
config.json
singbox_config.json
singbox_config.json.bak
sing-box.exe.bak
sing-box.bak
cache.db
singbox.log
*.bak

# Subscription cache
subscriptions/
subscription-cache/

# Any local override configs
local.config.*
*.local.json

# NaiveProxy 核心库（由 npm run fetch:cronet 下载，打包时随 resources 打入；体积大不入库）
resources/*/libcronet.*
