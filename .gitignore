# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build output
dist/
dist-ssr/
dist-package/
release/
*.local
*.asar

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs (anchor to repo root so 源码目录 src/.../components/logs/ 不被误忽略)
*.log
/[Ll]og/
/[Ll]ogs/

# Test files
samples/
*.test.exe

# Development scripts (keep in repo but ignore generated)
scripts/*.exe

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini

# Temporary files
*.tmp
*.temp

# Local test files (may contain private config)
test-*.json

# ── Sensitive runtime data (NEVER commit) ──────────────────────────────
# User proxy configs & node lists (stored in OS userData dir at runtime,
# but guard against any accidental copies landing in the repo)
config.json
singbox_config.json
singbox_config.json.bak
sing-box.exe.bak
sing-box.bak
cache.db
singbox.log
*.bak

# Subscription cache
subscriptions/
subscription-cache/

# Any local override configs
local.config.*
*.local.json

# NaiveProxy 核心库（由 npm run fetch:cronet 下载，打包时随 resources 打入；体积大不入库）
resources/*/libcronet.*

# macOS 提权 helper 二进制（由 npm run build:helper 交叉编译；构建产物不入库，CI 现编现打）
resources/*/com.flowz.helper

# ── 误落到 repo 根的产物 / 运行时临时文件（不入库；gitignore 不支持行内注释，注释独立成行）──
# 运行时 PID 文件（py.pid / sb2.pid 等）
*.pid
# 临时 sing-box 测试配置 / rule set 测试文件
/cfg2.json
/rsf.json
# 误编译到根目录的产物（源码在 src/main/services/*.ts；jest.config.js 等合法根 .js 不受影响）
/HelperManager.js
/ProxyManager.js

# ── 本地设计文档（含 Obsidian wikilink / 内部过程，本地保留不入 PR）──────
docs/design/
# 本地真机验证清单（同 design 性质：含内部过程，不入 PR）
docs/validation-checklist.md

# tsc 增量编译产物（防 tsc 增量后再次变 untracked 误提交）
*.tsbuildinfo

# 构建时注入的构建日期常量（scripts/gen-build-info.js 生成；每次 build 覆写，不入库）
src/shared/build-info.ts

# ── 误落到 repo 根的本地文件（Obsidian 临时画布 / daily note / 误编译 helper 产物）──
/Untitled.canvas
/2026-06-13.md
/helper/flowzhelper
